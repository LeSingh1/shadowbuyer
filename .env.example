# Copy this to .env and fill in real values. .env is gitignored.

# Bright Data — https://get.brightdata.com/aibuilders10
# Web Scraper API token, or Web Unlocker credentials
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_ZONE=                # e.g. "web_unlocker1" or your zone name
BRIGHTDATA_CUSTOMER_ID=         # optional, for proxy auth pattern
BRIGHTDATA_PASSWORD=            # optional, for proxy auth pattern

# Actionbook — browser automation / form filling
ACTIONBOOK_API_KEY=
ACTIONBOOK_BASE_URL=https://api.actionbook.ai

# Evermind — persistent agent memory
EVERMIND_API_KEY=
EVERMIND_BASE_URL=https://api.evermind.ai
EVERMIND_NAMESPACE=shadowbuyer

# Nosana — decentralized GPU for embeddings (afternoon stretch)
NOSANA_API_KEY=
NOSANA_ENDPOINT=

# OpenAI/Anthropic fallback for embeddings if Nosana is too painful
OPENAI_API_KEY=
