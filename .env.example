# Copy to .env locally; populate as keys arrive. Missing keys keep mocks live.
# Every variable is OPTIONAL — the pipeline runs end-to-end with all of them empty.

# TokenRouter — ALL LLM calls route through it (Qwen, Z.ai, OpenAI)
TOKENROUTER_API_KEY=
TOKENROUTER_BASE_URL=https://api.tokenrouter.io/v1
# Provider prefix overrides — set if TokenRouter's actual model-id convention differs.
# Defaults assume "{provider}/{model}" e.g. qwen/qwen3-max, zai/glm-5.1
TOKENROUTER_QWEN_PREFIX=qwen
TOKENROUTER_ZAI_PREFIX=zai
TOKENROUTER_OPENAI_PREFIX=openai

# Qwen / Z.ai direct keys — currently unused (everything goes through TokenRouter).
# Kept for the sponsor audit and in case TokenRouter forwarding is bypassed.
QWEN_API_KEY=
ZAI_API_KEY=

# Evermind — persistent memory for vendor profiles, AE quotes, trash-talk, decisions.
EVERMIND_API_KEY=
EVERMIND_BASE_URL=https://api.evermind.ai
EVERMIND_PATH_TEMPLATE=/v1/namespaces/{namespace}/keys/{key}

# Nosana — sentence-transformers embedding endpoint for Contract Diff.
# Expected: POST {endpoint}/embed body {texts:[...]} -> {embeddings:[[...]]}
NOSANA_ENDPOINT=

# Bright Data — Person B's scrape feed for the Scout agent.
BRIGHTDATA_API_KEY=
